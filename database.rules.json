{
  "rules": {

    "court": {
      ".read": true,
      ".write": true,

      "people": {
        "$personId": {
          ".validate": "newData.hasChildren(['id','name','gender','amt'])",
          "id":     { ".validate": "newData.isNumber() && newData.val() == $personId" },
          "name":   { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40" },
          "gender": { ".validate": "newData.val() == 'm' || newData.val() == 'f'" },
          "amt":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000 && newData.val() % 2 == 0" },
          "$other": { ".validate": false }
        }
      },

      "nextId": { ".validate": "newData.isNumber() && newData.val() >= 0" },

      "auditLog": {
        "$entryId": {
          // write-once: an entry can be created, but never edited or deleted —
          // this is what makes the history trustworthy as evidence.
          ".validate": "!data.exists() && newData.hasChildren(['action','by','ts'])",
          "action": { ".validate": "newData.isString() && newData.val().length <= 30" },
          "by":     { ".validate": "newData.isString() && newData.val().length <= 40" },
          "ts":     { ".validate": "newData.isNumber()" }
        }
      }
    },

    "backups": {
      ".read": true,
      ".write": true,
      "$backupId": {
        // same write-once protection — a saved snapshot can't be quietly altered.
        ".validate": "!data.exists() && newData.hasChildren(['people','ts','by'])"
      }
    },

    "chat": {
      ".read": true,
      ".write": true,
      "messages": {
        "$msgId": {
          ".validate": "!data.exists() && newData.hasChildren(['name','text','ts'])",
          "name": { ".validate": "newData.isString() && newData.val().length <= 40" },
          "text": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 1000" },
          "ts":   { ".validate": "newData.isNumber()" }
        }
      }
    },

    "notifications": {
      ".read": true,
      ".write": true,
      "tokens": {
        "$token": {
          ".validate": "newData.hasChildren(['name','ts'])",
          "name": { ".validate": "newData.isString() && newData.val().length <= 40" },
          "ts":   { ".validate": "newData.isNumber()" }
        }
      }
    }

  }
}
